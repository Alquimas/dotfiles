# Default modkey
set $mod Mod4
set $alt Mod1

# Load config files
include ~/.config/i3/config_files/theme.conf
include ~/.config/i3/config_files/keybindings.conf
include ~/.config/i3/config_files/fonts.conf

# Use Mouse+$mod to drag floating windows to their wanted position
floating_modifier $mod

for_window [class = "Nm-connection-editor"] floating enable
for_window [class = "Alacritty-float"] floating enable

# startup aplicattions
exec --no-startup-id $HOME/.config/i3/scripts/battery_warning.sh
exec --no-startup-id $HOME/.config/i3/scripts/volume_deamon.sh
exec --no-startup-id $HOME/.config/i3/scripts/brightness_deamon.sh
exec --no-startup-id dunst
exec --no-startup-id nm-applet
exec --no-startup-id xautolock -time 5 -locker "light-locker"
exec --no-startup-id xss-lock --transfer-sleep-lock -- light-locker
exec_always --no-startup-id $HOME/.config/i3/scripts/set_wallpaper.sh
exec_always --no-startup-id picom
exec_always --no-startup-id $HOME/.config/polybar/launch.sh
